exports[`chart snapshots — aequorin — two series — mean line + SD ribbon, grid 1`] = `"<svg viewBox="0 0 700 470" style="width:100%;height:auto;display:block" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ca2+ Response"><title>Ca2+ Response</title><desc>Time series chart with 2 series, X: Time (s), Y: Luminescence (RLU)</desc><g id="title"><text x="350" y="17" text-anchor="middle" font-size="15" font-weight="700" fill="#222" font-family="sans-serif">Ca2+ Response</text></g><g id="chart" transform="translate(0, 20)"><rect id="plot-area-background" x="62" y="20" width="618" height="382" fill="#fff"></rect><g id="grid"><line x1="62" x2="680" y1="402" y2="402" stroke="#eee" stroke-width="0.50"></line><line x1="62" x2="680" y1="325.60" y2="325.60" stroke="#eee" stroke-width="0.50"></line><line x1="62" x2="680" y1="249.20" y2="249.20" stroke="#eee" stroke-width="0.50"></line><line x1="62" x2="680" y1="172.80" y2="172.80" stroke="#eee" stroke-width="0.50"></line><line x1="62" x2="680" y1="96.40" y2="96.40" stroke="#eee" stroke-width="0.50"></line><line x1="62" x2="680" y1="20" y2="20" stroke="#eee" stroke-width="0.50"></line><line x1="62" x2="62" y1="20" y2="402" stroke="#eee" stroke-width="0.50"></line><line x1="216.50" x2="216.50" y1="20" y2="402" stroke="#eee" stroke-width="0.50"></line><line x1="371" x2="371" y1="20" y2="402" stroke="#eee" stroke-width="0.50"></line><line x1="525.50" x2="525.50" y1="20" y2="402" stroke="#eee" stroke-width="0.50"></line><line x1="680" x2="680" y1="20" y2="402" stroke="#eee" stroke-width="0.50"></line></g><g id="ribbons"><path id="ribbon-WT" d="M62.00,233.92L371.00,65.84L680.00,149.88L680.00,195.72L371.00,126.96L62.00,264.48Z" fill="#648FFF" fill-opacity="0.20" stroke="#648FFF" stroke-opacity="0.20" stroke-width="0.50"></path><path id="ribbon-Mutant" d="M62.00,264.48L371.00,188.08L680.00,241.56L680.00,287.40L371.00,249.20L62.00,295.04Z" fill="#DC267F" fill-opacity="0.20" stroke="#DC267F" stroke-opacity="0.20" stroke-width="0.