#!/usr/bin/env bash
# Pre-commit hook: keeps compiled outputs in sync with source.
#
# Problem it solves: tools/<tool>.js.map files inline _shell/*.ts content via
# sourcesContent. If any _shell/* or helpers.ts file changes and the committer
# forgets to rebuild, the committed .map goes stale — CI rebuilds then report
# a dirty working tree, merges conflict, and cross-tool sourcemap drift
# sneaks in (we lived this during the tool-helpers-split merge to master).
#
# Strategy: if staged changes touch anything that affects the build
# (tools/*.tsx, tools/*/*.ts(x), tools/_shell/*, tools/_core/*,
# scripts/build-shared.js, scripts/write-version.js), rebuild and re-stage
# any compiled output whose post-build content differs from the index.
#
# Audit-23 #14: stash unstaged + untracked changes before rebuild so the
# build reflects only the about-to-commit state. Re-stage paths whose diff
# is non-empty relative to the INDEX (not the working tree) — otherwise
# pre-existing unstaged drift in compiled outputs would get pulled into an
# unrelated source commit. Pop the stash on exit; if pop conflicts (because
# the user had a deliberate hot-patch on a compiled output that the rebuild
# also touched), leave the stash in place with a clear warning so they can
# resolve it manually. Bypass with `git commit --no-verify` if you truly
# need to commit without rebuilding (e.g. reverting only compiled outputs).

set -euo pipefail

# Files whose edits invalidate compiled outputs.
affects_build() {
  git diff --cached --name-only --diff-filter=ACMR | \
    grep -E '^(tools/[^/]+\.(tsx|ts)$|tools/[^/]+/.*\.(ts|tsx)$|scripts/(build-shared|write-version|vendor-sri)\.js$|vendor/.*\.js$)' \
    || true
}

STAGED=$(affects_build)
if [ -z "$STAGED" ]; then
  exit 0
fi

echo "[pre-commit] Source files staged — rebuilding to keep compiled outputs in sync:"
echo "$STAGED" | sed 's/^/  /'

# Stash unstaged + untracked so the rebuild reflects only the staged state.
# --keep-index keeps staged content in the working tree (so the build sees
# what's about to be committed). --include-untracked covers any new files
# the developer has dropped into the tree but not `git add`'d yet.
DID_STASH=0
if ! git diff --quiet || ! git diff --cached --quiet || \
   [ -n "$(git ls-files --others --exclude-standard)" ]; then
  # Only stash when there's something to stash AND not everything is staged.
  if [ -n "$(git status --porcelain | grep -v '^[AMDR] ')" ]; then
    if git stash push --keep-index --include-untracked --quiet \
         --message "pre-commit-rebuild-$(date +%s)"; then
      DID_STASH=1
    fi
  fi
fi

restore_stash() {
  if [ "$DID_STASH" = "1" ]; then
    if ! git stash pop --quiet 2>/dev/null; then
      echo
      echo "[pre-commit] WARNING: git stash pop conflicted — your unstaged work"
      echo "             is preserved in stash@{0}. Resolve manually after the"
      echo "             commit lands, or run \`git stash drop\` if you no longer"
      echo "             need it."
      echo
      echo "             Common case (the conflict is a re-built compiled output"
      echo "             that drifted from your unstaged copy):"
      echo "               git checkout --theirs tools/<file>.js tools/<file>.js.map"
      echo "               git add tools/<file>.js tools/<file>.js.map"
      echo "               git stash drop"
      echo "             '--theirs' here is the freshly-rebuilt version on disk;"
      echo "             '--ours' is the stashed pre-rebuild copy."
    fi
  fi
}
trap restore_stash EXIT

# Rebuild. The `prebuild` npm script wipes tools/_app/chunks/ first (esbuild's
# `--splitting --chunk-names=chunks/[name]-[hash]` is deterministic but doesn't
# garbage-collect, so a tool whose hash changes would otherwise leave its prior
# chunk tracked-but-unreferenced — and `git diff` reports no drift because the
# stale file is still on disk). With prebuild doing the wipe, the same cleaning
# runs in CI/deploy too, so the "Verify compiled sources in sync" diff can catch
# orphaned chunks. prebuild also regenerates tools/version.js and
# tools/shared.bundle.js, so we don't need separate invocations here.
npm run --silent build >/dev/null

# Compiled-output pathspec — every glob below is a path whose content is
# derived from source and should be kept in lock-step with what's about
# to be committed. Kept as a bash array so it can be passed verbatim to
# both `git status` (for the user-visible echo) and `git add -A` (for
# the actual restage).
COMPILED_PATHSPEC=(
  'tools/*.js'
  'tools/*.js.map'
  'tools/*/index.js'
  'tools/*/index.js.map'
  'tools/_app/index.js'
  'tools/_app/index.js.map'
  'tools/_app/chunks/*.js'
  'tools/_app/chunks/*.js.map'
  'tools/shared.bundle.js'
  'tools/version.js'
  'tools/*.html'
  'index.html'
)
# shared.bundle.js.map intentionally omitted: scripts/build-shared.js
# concatenates source files literally with no sourcemap output, so the
# .map sibling never exists and including it would make
# `git add -A -- <pathspec>` fail with "did not match any files" on
# every pre-commit run.

# Enumerate post-rebuild drift between the working tree and the index
# in the compiled-output paths. We care about Y-column changes (working-
# tree-vs-index) since pre-rebuild staging is already correct; the
# hook should only pick up new drift introduced by the rebuild itself.
#
# `git status --porcelain` two-char status XY:
#   X = index-vs-HEAD,  Y = worktree-vs-index
#
# Lines we WANT to stage:
#   - ` M` (worktree modified, not yet staged)            — rebuilt file
#   - `MM` (both staged and unstaged modifications)       — rebuild diverged from pre-stage
#   - ` D` (worktree deleted, not yet staged)             — stale-chunk wipe
#   - `??` (untracked)                                    — new content-hashed chunk emit
#
# Lines we DON'T want to re-stage:
#   - `M ` / `A ` / `D ` / `R ` (Y is space)              — already staged, no drift
#
# Rename rows (X=R) print as `R  old -> new`; when Y is space they're
# already staged and we skip. If a rename's Y were non-space (rare),
# the `-> ` arrow would confuse `git add` — parse out the new path.
REBUILT=$(git status --porcelain -- "${COMPILED_PATHSPEC[@]}" 2>/dev/null \
  | awk '
      {
        x = substr($0, 1, 1);
        y = substr($0, 2, 1);
        # Untracked: XY = "??"; treat as a change to stage.
        if (x == "?" && y == "?") {
          print substr($0, 4);
          next;
        }
        # Skip already-fully-staged lines (Y is a space).
        if (y == " ") next;
        path = substr($0, 4);
        # Rename rows look like "old -> new"; keep only the new path.
        if (match(path, / -> /)) path = substr(path, RSTART + 4);
        print path;
      }
    ' || true)

if [ -n "$REBUILT" ]; then
  echo "[pre-commit] Re-staging rebuilt outputs:"
  echo "$REBUILT" | sed 's/^/  /'
  # Stage the enumerated paths. Each came from `git status --porcelain`
  # so git already recognises it; `git add -A -- <each>` handles
  # modifications, new files, AND deletions consistently. xargs -I {}
  # invokes git per path so a single bogus entry can't block the rest
  # (which the previous flat `git add -A -- <pathspec>` couldn't —
  # one no-match glob in the pathspec aborted the whole call).
  printf '%s\n' "$REBUILT" | xargs -I {} git add -A -- "{}"
fi

exit 0
