{
  "name": "plottr",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "node scripts/write-version.js && node scripts/build-shared.js && node scripts/vendor-sri.js && node scripts/anti-clickjack-sync.js",
    "build": "esbuild tools/boxplot/index.tsx tools/scatter/index.tsx tools/aequorin/index.tsx tools/lineplot/index.tsx tools/venn/index.tsx tools/heatmap/index.tsx tools/molarity.tsx tools/power.tsx tools/upset/index.tsx tools/volcano/index.tsx --bundle --format=esm --outdir=tools --jsx=transform --minify-syntax --minify-whitespace --sourcemap",
    "build:shared": "node scripts/build-shared.js",
    "prewatch": "node scripts/write-version.js",
    "watch": "node scripts/watch.js",
    "pretest": "node scripts/build-shared.js",
    "test": "node scripts/run-tests.js",
    "posttest": "node scripts/bump-test-count.js",
    "fuzz:heatmap": "node tests/fuzz/heatmap.fuzz.js",
    "fuzz:boxplot": "node tests/fuzz/boxplot.fuzz.js",
    "fuzz:scatter": "node tests/fuzz/scatter.fuzz.js",
    "fuzz:aequorin": "node tests/fuzz/aequorin.fuzz.js",
    "fuzz:lineplot": "node tests/fuzz/lineplot.fuzz.js",
    "fuzz:venn": "node tests/fuzz/venn.fuzz.js",
    "fuzz:upset": "node tests/fuzz/upset.fuzz.js",
    "fuzz:volcano": "node tests/fuzz/volcano.fuzz.js",
    "benchmark": "Rscript benchmark/run-r.R && node benchmark/run.js && node benchmark/run-r-export.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:sri": "node scripts/vendor-sri.js --check",
    "lint:anti-clickjack": "node scripts/anti-clickjack-sync.js --check",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "prepare": "node scripts/hooks/install.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.59.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
